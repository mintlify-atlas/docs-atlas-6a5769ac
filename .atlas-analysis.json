  "keyFeatures": [
    "For You timeline generation with ML-powered ranking",
    "Candidate sourcing from multiple signals (Earlybird, UTEG, GraphJet)",
    "SimClusters community detection and sparse embeddings",
    "TwHIN dense knowledge graph embeddings",
    "Follow recommendations with personalized account suggestions",
    "Trust and safety models (NSFW, toxicity, abuse detection)",
    "High-performance ML serving with Navi (Rust)",
    "Real-time user action streaming and processing",
    "Product Mixer framework for building content feeds",
    "Visibility filtering and content quality controls"
  ],
  "publicApiSurface": [
    "HomeMixerServer - Main service for constructing Home Timelines",
    "CrMixerServer - Candidate generation coordination service",
    "FollowRecommendationsService - Account follow suggestions",
    "PushService - Notification recommendations",
    "NaviPredictService - ML model serving via gRPC",
    "TweetypieService - Tweet read/write operations",
    "UserSignalService - User interaction signals",
    "GraphFeatureService - Graph-based features for user pairs",
    "RepresentationScorer - Embedding similarity scoring",
    "TimelineRanker - Legacy relevance scoring service"
  ]
